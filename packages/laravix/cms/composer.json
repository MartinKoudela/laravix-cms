{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravix/cms",
    "type": "library",
    "description": "Laravix CMS core — a multi-tenant content management system built on Laravel and Filament.",
    "keywords": [
        "laravel",
        "filament",
        "cms",
        "multi-tenant",
        "content-management"
    ],
    "license": "GPL-3.0-or-later",
    "require": {
        "bezhansalleh/filament-language-switch": "^4.3",
        "devonab/filament-easy-footer": "^2.0",
        "ext-fileinfo": "*",
        "filament/filament": "^5.0",
        "http-interop/http-factory-guzzle": "^1.2",
        "intervention/image-laravel": "^4.0",
        "laravel/framework": "^13.0",
        "laravel/scout": "^11.3",
        "meilisearch/meilisearch-php": "^1.16",
        "php": "^8.4",
        "promethys/revive": "^3.0",
        "spatie/laravel-activitylog": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Laravix\\Cms\\": "src/",
            "Laravix\\Cms\\Database\\Factories\\": "database/factories/",
            "Laravix\\Cms\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laravix\\Cms\\CmsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
